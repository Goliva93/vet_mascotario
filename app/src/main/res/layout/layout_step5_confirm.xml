<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Revisa la información"
        android:textColor="@color/text_dark"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Confirma los datos antes de registrar la cita"
        android:textColor="@color/text_gray"
        android:textSize="14sp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        app:cardBackgroundColor="@color/bg_white"
        app:cardCornerRadius="20dp"
        app:cardElevation="3dp"
        app:strokeColor="@color/profile_card_stroke"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/tv_confirm_pet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mascota: Luna"
                android:textColor="@color/text_dark"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tv_confirm_service"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Servicio: Consulta médica"
                android:textColor="@color/text_dark"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tv_confirm_branch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Sede: Chorrillos"
                android:textColor="@color/text_dark"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tv_confirm_date_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Fecha y hora: 2026-03-20 · 10:00 - 11:00"
                android:textColor="@color/text_dark"
                android:textSize="15sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:text="Observaciones"
        android:textColor="@color/text_dark"
        android:textSize="16sp"
        android:textStyle="bold" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_confirm_notes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusBottomEnd="16dp"
        app:boxCornerRadiusBottomStart="16dp"
        app:boxCornerRadiusTopEnd="16dp"
        app:boxCornerRadiusTopStart="16dp"
        app:boxStrokeColor="@color/btn_outline_border">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_confirm_notes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top|start"
            android:hint="Observaciones opcionales para la cita"
            android:inputType="textMultiLine"
            android:minLines="4"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/status_neutral" />
    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>